{
  "manifest_version": 3,
  "name": "ExcaliSave",
  "version": "1.0.0",
  "description": "Save Excalidraw drawings to your browser",
  "permissions": ["storage", "identity", "identity.email", "tabs"],
  "host_permissions": [
    "https://login.microsoftonline.com/*",
    "https://graph.microsoft.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
